# Telegram Bot tokeni — @BotFather dan olish
BOT_TOKEN=

# Mini App URL — Railway deployment URL + /app
MINI_APP_URL=https://yourdomain.up.railway.app/app

# Webhook URL — Railway deployment URL
WEBHOOK_URL=https://yourdomain.up.railway.app

# PostgreSQL ulanish URL — Railway PostgreSQL dan olish
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Telegram API credentials — https://my.telegram.org dan olish
API_ID=
API_HASH=

# Fernet shifrlash kaliti — python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
